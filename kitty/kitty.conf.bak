# kitty.conf - Generated by Confitty (2026-04-16)
# Place this file at: ~/.config/kitty/kitty.conf
# Reload without restart: Ctrl+Shift+F5  |  Docs: https://sw.kovidgoyal.net/kitty/conf/
# Only settings that differ from Kitty defaults are included.

# --- Fonts ---
font_family FiraCode Nerd Font

# --- Cursor ---
cursor_blink_interval 0
cursor_shape block
cursor_shape_unfocused hollow
shell_integration no-cursor

# --- Scrollback ---
scrollback_lines 10000

# --- Mouse ---
copy_on_select clipboard

# --- Bell ---
window_alert_on_bell no

# --- Window Layout ---
enabled_layouts splits
window_border_width 1pt
confirm_os_window_close 1

# --- Tab Bar ---
tab_bar_style custom
tab_bar_min_tabs 2
active_tab_foreground #000000
active_tab_background #abb2bf
inactive_tab_foreground #FFFFFF
inactive_tab_background #47474f
# --- Colors ---
foreground #abb2bf
background #282c34
selection_foreground #abb2bf
selection_background #3e4451
color0 #282c34
color1 #e06c75
color2 #98c379
color3 #e5c07b
color4 #61afef
color5 #c678dd
color6 #56b6c2
color7 #abb2bf
color8 #5c6370
color9 #e06c75
color10 #98c379
color11 #e5c07b
color12 #61afef
color13 #c678dd
color14 #56b6c2

# --- Advanced ---
allow_remote_control socket-only

# --- Keyboard Shortcuts ---
map ctrl+alt+r launch --location=vsplit --cwd=current
map ctrl+alt+d launch --location=hsplit --cwd=current
map ctrl+alt+w close_window
map alt+left neighboring_window left
map alt+right neighboring_window right
map alt+up neighboring_window up
map alt+down neighboring_window down
map ctrl+alt+1 goto_tab 1
map ctrl+alt+2 goto_tab 2
map ctrl+alt+3 goto_tab 3
map ctrl+alt+4 goto_tab 4
map ctrl+alt+5 goto_tab 5
map ctrl+alt+6 goto_tab 6
map ctrl+alt+7 goto_tab 7
map ctrl+alt+8 goto_tab 8
map ctrl+alt+9 goto_tab 9

